# ─── Server ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────
DEV_DB_URL=mongodb://localhost:27017/slack-clone-dev
PROD_DB_URL=mongodb://localhost:27017/slack-clone-prod

# ─── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-here-min-16-chars
JWT_EXPIRY=1d

# ─── Mail (Gmail SMTP) ───────────────────────────────────────────────
MAIL_ID=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── App ──────────────────────────────────────────────────────────────
APP_LINK=http://localhost:3000
ENABLE_EMAIL_VERIFICATION=false

# ─── Image Upload ──────────────────────────────────────────────────────
# Which provider to use: 'imagekit' or 's3'
IMAGE_UPLOAD_PROVIDER=imagekit

# ─── AWS S3 ──────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# ─── ImageKit ────────────────────────────────────────────────────────
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# ─── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── CORS ────────────────────────────────────────────────────────────
CORS_ORIGIN=*
